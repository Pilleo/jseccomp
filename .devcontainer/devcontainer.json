{
  "name": "jseccomp Dev Environment",
  "dockerComposeFile": "../docker-compose.yml",
  "service": "jseccomp",
  "workspaceFolder": "/workspace",
  "remoteEnv": {
    "JAVA_HOME": "/opt/java/openjdk",
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "vscjava.vscode-java-pack",
        "vscjava.vscode-gradle",
        "fwcd.kotlin",
      ],
    },
  },
}
